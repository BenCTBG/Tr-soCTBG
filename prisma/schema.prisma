generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  COMPTABLE
  ADV
  ADV_RESTREINT
  OPERATEUR
}

enum AlertLevel {
  NORMAL
  ATTENTION
  CRITIQUE
  NEGATIF
}

enum ReceiptType {
  CLIENT_DIRECT
  CEE
  MPR
  AVOIR
  AUTRE
}

enum ReceiptStatus {
  ATTENDU
  ENCAISSE
  EN_RETARD
  ANNULE
}

enum DisbursementPriority {
  IMMEDIAT
  SOUS_3J
  SOUS_15J
  SOUS_1_MOIS
  ATTENTE
  BLOQUE
}

enum DisbursementStatus {
  A_PAYER
  EN_ATTENTE_DG
  VALIDE_DG
  PAYE
  ANNULE
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  bankPositions  BankPosition[]
  receipts       Receipt[]
  disbursements  Disbursement[]
  validatedDisbursements Disbursement[] @relation("ValidatedBy")
  auditLogs      AuditLog[]

  @@map("users")
}

model Entity {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  bankPositions BankPosition[]
  receipts      Receipt[]
  disbursements Disbursement[]

  @@map("entities")
}

model BankPosition {
  id              String     @id @default(uuid())
  date            DateTime   @db.Date
  entityId        String     @map("entity_id")
  balance         Decimal    @db.Decimal(12, 2)
  previousBalance Decimal    @map("previous_balance") @db.Decimal(12, 2)
  variation       Decimal    @db.Decimal(12, 2)
  alertLevel      AlertLevel @map("alert_level")
  createdBy       String     @map("created_by")
  createdAt       DateTime   @default(now()) @map("created_at")

  entity Entity @relation(fields: [entityId], references: [id])
  user   User   @relation(fields: [createdBy], references: [id])

  @@unique([date, entityId])
  @@map("bank_positions")
}

model Receipt {
  id            String        @id @default(uuid())
  expectedDate  DateTime      @map("expected_date") @db.Date
  entityId      String        @map("entity_id")
  invoiceNumber String        @map("invoice_number")
  clientName    String        @map("client_name")
  siteAddress   String?       @map("site_address")
  amountTtc     Decimal       @map("amount_ttc") @db.Decimal(12, 2)
  type          ReceiptType
  status        ReceiptStatus @default(ATTENDU)
  receivedDate  DateTime?     @map("received_date") @db.Date
  observations  String?
  createdBy     String        @map("created_by")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  entity Entity @relation(fields: [entityId], references: [id])
  user   User   @relation(fields: [createdBy], references: [id])

  @@map("receipts")
}

model Disbursement {
  id             String               @id @default(uuid())
  receivedDate   DateTime             @map("received_date") @db.Date
  entityId       String               @map("entity_id")
  supplier       String
  siteRef        String?              @map("site_ref")
  amountHt       Decimal?             @map("amount_ht") @db.Decimal(12, 2)
  amountTtc      Decimal              @map("amount_ttc") @db.Decimal(12, 2)
  priority       DisbursementPriority
  paymentDueDate DateTime?            @map("payment_due_date") @db.Date
  status         DisbursementStatus   @default(A_PAYER)
  validatedBy    String?              @map("validated_by")
  paidDate       DateTime?            @map("paid_date") @db.Date
  fileUrl        String?              @map("file_url")
  observations   String?
  createdBy      String               @map("created_by")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  entity    Entity @relation(fields: [entityId], references: [id])
  user      User   @relation(fields: [createdBy], references: [id])
  validator User?  @relation("ValidatedBy", fields: [validatedBy], references: [id])

  @@map("disbursements")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  action    String
  module    String
  details   Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("audit_log")
}
